rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Uses exists() — does NOT require a read permission on /admins
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Uses exists() — does NOT require a read permission on /volunteers
    function isVolunteer() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/volunteers/$(request.auth.uid));
    }

    // True when the authenticated user owns the document (keyed by their UID)
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Restricts a self-update to a fixed allow-list of non-privileged fields
    // (e.g. lastLogin) so an owner can never modify their own role/existence
    // via a client-side write — role documents may only be CREATED/DELETED
    // by an admin (or, for the very first admin, by the Admin SDK seed script,
    // which is not subject to these rules at all).
    function onlyChangedFields(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // ── Role Profiles ─────────────────────────────────────────────────────────

    // SECURITY: role documents (admins/volunteers) must never be self-creatable —
    // that is a privilege-escalation vector. Only an existing admin may create,
    // update role fields, or delete another admin/volunteer document. The single
    // admin account is seeded once via scripts/seedAdmin.ts (Firebase Admin SDK,
    // which bypasses these rules entirely), never through client code.
    match /admins/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isAdmin();
      // An admin may update anything; the owner may only touch lastLogin.
      allow update: if isAdmin() || (isOwner(uid) && onlyChangedFields(['lastLogin']));
      allow delete: if isAdmin();
    }

    // Volunteers are always created by an admin (adminCreateVolunteer). A
    // volunteer may only touch their own lastLogin field — role/active/gate
    // assignment stays admin-controlled.
    match /volunteers/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isOwner(uid) && onlyChangedFields(['lastLogin']));
      allow delete: if isAdmin();
    }

    // Fans can read/write their own profile; admins can read all
    match /fans/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── Operational Collections ───────────────────────────────────────────────

    // Tasks: visible to all logged-in users; volunteers & admins may update
    match /tasks/{taskId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isVolunteer() || isAdmin();
      allow delete: if isAdmin();
    }

    // Food orders: fans & anyone authenticated can create; volunteers & admins can update
    match /foodOrders/{orderId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isVolunteer() || isAdmin();
      allow delete: if isAdmin();
    }

    // Emergency requests: any authenticated user can create; volunteers & admins can update
    match /emergencyRequests/{reqId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isVolunteer() || isAdmin();
      allow delete: if isAdmin();
    }

    // Issue reports: any authenticated user can create; volunteers & admins can update
    match /issueReports/{reportId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isVolunteer() || isAdmin();
      allow delete: if isAdmin();
    }

    // Matches: all authenticated users can read; only admins can write
    match /matches/{matchId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // System config: all authenticated users can read; only admins can write
    match /systemConfig/{configId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
