rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user is admin
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: Is resource belonging to self
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Admin collection rules
    match /admins/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
    }

    // Volunteer collection rules
    match /volunteers/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
    }

    // Fan collection rules
    match /fans/{uid} {
      allow read, write: if isAdmin() || isOwner(uid);
    }
  }
}
