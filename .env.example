# Nexus AI — environment variables and secrets
#
# This file lists every environment variable/secret referenced anywhere in
# the codebase (app code, server, and one-off scripts), annotated as
# REQUIRED or OPTIONAL. "Required" means the app throws/refuses to start
# without it. Everything else degrades gracefully — see the note on each.
#
# On Replit: set REQUIRED and any OPTIONAL values you want via the Secrets
# panel (do not commit real values here). This file is documentation only
# and is never loaded by the app.

# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — client-side Firebase config (src/firebase.ts throws at startup
# if any of these are missing; Firebase Auth/Firestore cannot function
# without them). Values are public client identifiers, not secrets.
# ─────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — app runs and degrades gracefully without these.
# ─────────────────────────────────────────────────────────────────────────

# Alternate source for the Firebase Web API key (src/firebase.ts accepts
# either VITE_FIREBASE_API_KEY or this). Not needed if VITE_FIREBASE_API_KEY
# is set.
GOOGLE_API_KEY=""

# Gemini API key for AI chat (server.ts). Missing -> genAI client is never
# created and /api/ai/command / /api/ai/demo-command fall back to the
# n8n webhook (if configured) or the local rule-based response engine.
# No startup failure either way.
GEMINI_API_KEY=""

# Full Firebase service account JSON (as one string) for the server-side
# Admin SDK (lib/firebaseAdmin.ts). Missing -> isAdminSdkConfigured()
# returns false and:
#   - `/api/config` (GET/POST) and the authenticated `/api/ai/command`
#     route fail with 401 (they call requireAuth/requireAdmin, which need
#     the Admin SDK to verify ID tokens and check admin status).
#   - `npm run verify:admin` and `scripts/seedAdmin.ts` cannot run.
# Everything else — client-side Firestore reads/writes for all dashboards,
# Demo Mode, and the unauthenticated `/api/ai/demo-command` route — is
# unaffected, since those go through the client Firebase SDK, not the
# Admin SDK.
FIREBASE_SERVICE_ACCOUNT_KEY=""

# reCAPTCHA v3 site key that activates Firebase App Check on the client
# (src/firebase.ts). Missing -> App Check silently never initializes; no
# behavior change. See README.md "Firebase App Check".
VITE_FIREBASE_APPCHECK_SITE_KEY=""

# Server-side flag (not a secret) that turns on App Check ENFORCEMENT for
# `/api/config` and `/api/ai/command` (lib/firebaseAdmin.ts
# requireAppCheck). Any value other than the literal string "true" (including
# unset) means requests pass through unchecked. Do not set to "true" without
# also setting VITE_FIREBASE_APPCHECK_SITE_KEY, or the server will reject
# every request because the client never attaches a token.
ENFORCE_APP_CHECK="false"

# n8n webhook URLs (server.ts) for the AI chat routing pipeline (n8n first,
# then Gemini, then the local engine). Missing -> that hop is skipped, AI
# chat still works via Gemini/local fallback. Also configurable at runtime
# from the Organizer Dashboard's Integration Center (stored server-side
# in-memory, mirrored to Firestore `systemConfig`) — the env vars are only
# the initial/default values.
N8N_WEBHOOK_URL=""
N8N_AI_ASSISTANT_URL=""
VITE_N8N_WEBHOOK_PRODUCTION_URL=""

# One-time admin seeding script only (scripts/seedAdmin.ts) — never read by
# the running app. Required only when you actually run that script, and
# only alongside FIREBASE_SERVICE_ACCOUNT_KEY.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Dev-only Vite flag (vite.config.ts). Missing/anything but "true" -> normal
# HMR/file-watching behavior. Set to "true" to disable HMR and file
# watching (useful in constrained sandboxes).
DISABLE_HMR="false"
